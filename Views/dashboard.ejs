<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — SocialSurge</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <div class="topbar">
      <a href="/" class="logo">Social<span>Surge</span></a>
      <div class="nav-links" style="display:flex; align-items:center;">
        <div class="balance-pill">Balance: <span class="accent">₹<%= user.balance.toFixed(2) %></span></div>
        <a href="/wallet" class="btn btn-outline" style="margin-left:16px;">Add Funds</a>
        <a href="/logout" style="margin-left:16px;">Logout</a>
      </div>
    </div>

    <section class="section">
      <h2 class="section-title">Naya Order Place Karein</h2>
      <% if (typeof insufficientBalance !== 'undefined' && insufficientBalance) { %>
        <div class="error-box">Aapke wallet me itna balance nahi hai. Pehle Add Funds karein.</div>
      <% } %>
      <form method="POST" action="/order" class="card">
        <div class="field">
          <label>Service Chunein</label>
          <select name="service_id" required>
            <% services.forEach(s => { %>
              <option value="<%= s.id %>">
                <%= s.category %> — <%= s.name %> (₹<%= s.rate_per_1000 %>/1000, min <%= s.min_quantity %>, max <%= s.max_quantity %>)
              </option>
            <% }) %>
          </select>
        </div>
        <div class="field">
          <label>Link (jaha followers/likes/views chahiye)</label>
          <input type="url" name="link" placeholder="https://instagram.com/username" required>
        </div>
        <div class="field">
          <label>Quantity</label>
          <input type="number" name="quantity" placeholder="1000" required>
        </div>
        <button type="submit" class="btn btn-warm">Order Place Karein</button>
      </form>
    </section>

    <section class="section">
      <h2 class="section-title">Meri Orders</h2>
      <table>
        <thead>
          <tr><th>ID</th><th>Service</th><th>Quantity</th><th>Charge</th><th>Status</th><th>Date</th></tr>
        </thead>
        <tbody>
          <% myOrders.forEach(o => { %>
            <tr>
              <td>#<%= o.id %></td>
              <td><%= o.service_name %></td>
              <td><%= o.quantity %></td>
              <td>₹<%= o.charge.toFixed(2) %></td>
              <td><span class="status status-<%= o.status %>"><%= o.status %></span></td>
              <td><%= new Date(o.created_at).toLocaleDateString('hi-IN') %></td>
            </tr>
          <% }) %>
          <% if (myOrders.length === 0) { %>
            <tr><td colspan="6" style="color:var(--text-muted)">Abhi tak koi order nahi diya.</td></tr>
          <% } %>
        </tbody>
      </table>
    </section>
  </div>
</body>
</html>
