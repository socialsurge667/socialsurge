<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SocialSurge — Social Media Growth Panel</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container">
    <nav class="nav">
      <div class="logo">Social<span>Surge</span></div>
      <div class="nav-links">
        <a href="/login">Login</a>
        <a href="/signup" class="btn btn-primary">Sign Up</a>
      </div>
    </nav>

    <section class="hero">
      <h1>Har platform par<br><span class="accent">surge</span> laayein growth ka.</h1>
      <p>Instagram, YouTube, TikTok aur Facebook ke liye followers, likes aur views — fast delivery, affordable rates.</p>
      <a href="/signup" class="btn btn-warm">Free Account Banayein</a>

      <svg class="surge-line" viewBox="0 0 700 100" preserveAspectRatio="none">
        <path d="M0,80 C100,80 100,20 200,20 C300,20 300,60 400,60 C500,60 500,10 600,10 C650,10 660,30 700,15" />
      </svg>
    </section>

    <section class="section">
      <h2 class="section-title">Popular Services</h2>
      <div class="grid">
        <div class="card">
          <h3>Instagram Followers</h3>
          <p>High quality, real-looking profiles se delivery</p>
          <div class="price">₹120 / 1000</div>
        </div>
        <div class="card">
          <h3>YouTube Views</h3>
          <p>Retention ke saath real views</p>
          <div class="price">₹90 / 1000</div>
        </div>
        <div class="card">
          <h3>TikTok Followers</h3>
          <p>Tez delivery, safe aur secure</p>
          <div class="price">₹150 / 1000</div>
        </div>
      </div>
    </section>
  </div>
</body>
</html>
